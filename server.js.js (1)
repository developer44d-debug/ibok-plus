/* ===== LOGIN ===== */
app.post("/login", async (req,res)=>{
const u=await User.findOne({username:req.body.username});
if(!u) return res.status(400).send("User not found");

const ok=await bcrypt.compare(req.body.password,u.password);
if(!ok) return res.status(400).send("Wrong password");

const token=jwt.sign({id:u._id},"secret");

res.json({token});
});

/* ===== AUTH ===== */
function auth(req,res,next){
try{
const decoded = jwt.verify(req.headers.authorization,"secret");
req.userId = decoded.id;
next();
}catch{
res.status(401).send("Unauthorized");
}
}

/* ===== GET USER ===== */
app.get("/me", auth, async (req,res)=>{
const user = await User.findById(req.userId);
res.json(user);
});

/* ===== TRANSFER ===== */
app.post("/transfer", auth, async (req,res)=>{

const {toUser, amount} = req.body;

const from = await User.findById(req.userId);
const to = await User.findOne({username: toUser});

if(!to) return res.send("User not found");
if(from.balance < amount) return res.send("No balance");

from.balance -= amount;
to.balance += amount;

await from.save();
await to.save();

res.send("Transfer Done 💸");
});

